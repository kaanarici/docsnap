{
	"name": "docsnap",
	"version": "0.1.2",
	"description": "Pull public docs and text-heavy pages into a local Markdown folder for coding agents.",
	"license": "MIT",
	"author": "Kaan Aricioglu",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kaanarici/docsnap.git"
	},
	"bugs": {
		"url": "https://github.com/kaanarici/docsnap/issues"
	},
	"homepage": "https://github.com/kaanarici/docsnap#readme",
	"keywords": [
		"docs",
		"markdown",
		"agent",
		"ai",
		"llms"
	],
	"type": "module",
	"packageManager": "bun@1.3.11",
	"engines": {
		"bun": ">=1.3.0"
	},
	"bin": {
		"docsnap": "bin/docsnap"
	},
	"files": [
		"bin",
		"src",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"check": "bun run lint && bun run typecheck && bun run test && bun run size",
		"lint": "biome check .",
		"typecheck": "tsc --noEmit",
		"test": "bun scripts/regression.ts",
		"size": "bun scripts/size.ts",
		"publish:dry": "bun pm pack --dry-run"
	},
	"dependencies": {
		"defuddle": "^0.18.1",
		"linkedom": "^0.18.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@types/bun": "1.3.13",
		"typescript": "^5.9.3"
	}
}
